---
import { Phone, Mail, MessageCircle } from "lucide-react";

const pages = [
    { label: "Diensten", href: "/diensten/" },
    { label: "Projecten", href: "/projecten/" },
    { label: "Over Ons", href: "/over-ons/" },
    { label: "Contact", href: "/contact/" },
];

const werkgebied = [
    "Culemborg",
    "Tiel",
    "Geldermalsen",
    "Buren",
    "Beusichem",
    "Leerdam",
    "Neerrijnen",
];
---

<footer class="bg-dark pt-16 pb-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        {/* 4-column grid */}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">
            {/* Column 1 - Brand */}
            <div>
                <span class="text-white text-lg font-bold">Groenrijk Hoveniers</span>
                <p class="text-gray-400 text-sm mt-3">
                    Uw hovenier in de Betuwe. Tuinontwerp, aanleg en onderhoud.
                </p>
                <div class="flex gap-4 mt-6">
                    <a href="#" class="text-gray-500 hover:text-white text-sm transition-colors">Facebook</a>
                    <a href="#" class="text-gray-500 hover:text-white text-sm transition-colors">Instagram</a>
                    <a href="#" class="text-gray-500 hover:text-white text-sm transition-colors">LinkedIn</a>
                </div>
            </div>

            {/* Column 2 - Pagina's */}
            <div>
                <h3 class="text-xs tracking-widest uppercase text-gray-500 mb-4 font-medium">Pagina's</h3>
                <ul class="space-y-3">
                    {
                        pages.map((link) => (
                            <li>
                                <a
                                    href={link.href}
                                    class="text-gray-400 hover:text-white transition-colors text-sm"
                                >
                                    {link.label}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </div>

            {/* Column 3 - Contact */}
            <div>
                <h3 class="text-xs tracking-widest uppercase text-gray-500 mb-4 font-medium">Contact</h3>
                <ul class="space-y-3">
                    <li>
                        <a href="tel:0612345678" class="flex items-center text-gray-400 hover:text-white transition-colors text-sm">
                            <Phone className="w-4 h-4 text-primary mr-3 flex-shrink-0" />
                            06-1234 5678
                        </a>
                    </li>
                    <li>
                        <a href="mailto:info@groenrijkhoveniers.nl" class="flex items-center text-gray-400 hover:text-white transition-colors text-sm">
                            <Mail className="w-4 h-4 text-primary mr-3 flex-shrink-0" />
                            info@groenrijkhoveniers.nl
                        </a>
                    </li>
                    <li>
                        <a href="https://wa.me/31612345678" class="flex items-center text-gray-400 hover:text-white transition-colors text-sm" target="_blank" rel="noopener noreferrer">
                            <MessageCircle className="w-4 h-4 text-primary mr-3 flex-shrink-0" />
                            WhatsApp ons
                        </a>
                    </li>
                </ul>
            </div>

            {/* Column 4 - Werkgebied */}
            <div>
                <h3 class="text-xs tracking-widest uppercase text-gray-500 mb-4 font-medium">Werkgebied</h3>
                <ul class="space-y-3">
                    {
                        werkgebied.map((plaats) => (
                            <li>
                                <a
                                    href="#"
                                    class="text-gray-400 hover:text-white transition-colors text-sm"
                                >
                                    {plaats}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </div>
        </div>

        {/* Bottom bar */}
        <div class="border-t border-gray-800 mt-12 pt-8 flex flex-col md:flex-row justify-between items-center">
            <p class="text-gray-500 text-xs">&copy; 2026 Groenrijk Hoveniers</p>
            <a
                href="https://knapgemaakt.nl/"
                target="_blank"
                rel="noopener noreferrer"
                class="text-gray-500 hover:text-gray-300 text-xs mt-4 md:mt-0"
            >
                Website door KnapGemaakt.nl
            </a>
        </div>
    </div>
</footer>
