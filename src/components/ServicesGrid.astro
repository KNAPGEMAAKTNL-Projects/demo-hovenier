---
import FadeIn from "./ui/FadeIn";
import { PenTool, Hammer, Scissors } from "lucide-react";

const services = [
    {
        title: "Tuinontwerp",
        description:
            "Een doordacht ontwerp dat past bij uw woning en leefstijl. Van eerste schets tot volledig beplantingsplan.",
        link: "/diensten/#ontwerp",
        icon: PenTool,
    },
    {
        title: "Tuinaanleg",
        description:
            "Vakkundige realisatie met oog voor detail. Bestrating, overkappingen, vijvers en alles daartussenin.",
        link: "/diensten/#aanleg",
        icon: Hammer,
    },
    {
        title: "Tuinonderhoud",
        description:
            "Zorgeloos genieten van een verzorgde tuin. Snoeien, bemesten en seizoensonderhoud door vakmensen.",
        link: "/diensten/#onderhoud",
        icon: Scissors,
    },
];
---

<section class="py-20 md:py-28 bg-gray">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        {/* Section header - centered */}
        <div class="text-center">
            <span class="text-primary text-sm font-medium tracking-wide uppercase">Wat wij doen</span>
            <h2 class="text-3xl md:text-4xl font-bold text-dark mt-3">
                Onze Diensten
            </h2>
            <p class="text-gray-600 mt-4 max-w-2xl mx-auto">
                Wij combineren vakmanschap met creativiteit voor een tuin die bij u past.
            </p>
        </div>

        {/* 3-column icon card grid */}
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-16">
            {
                services.map((service, index) => (
                    <FadeIn client:visible delay={index * 0.15 + 0.2}>
                        <a
                            href={service.link}
                            class="group bg-white rounded-2xl shadow-sm hover:shadow-md transition-all duration-300 p-8 cursor-pointer block h-full"
                        >
                            <div class="w-14 h-14 bg-primary/10 rounded-xl flex items-center justify-center mb-6">
                                <service.icon className="text-primary w-7 h-7" />
                            </div>

                            <h3 class="text-xl font-bold text-dark mb-3">
                                {service.title}
                            </h3>

                            <p class="text-gray-600 leading-relaxed mb-6">
                                {service.description}
                            </p>

                            <span class="text-primary font-medium text-sm inline-flex items-center gap-2 group-hover:gap-3 transition-all">
                                Meer info &rarr;
                            </span>
                        </a>
                    </FadeIn>
                ))
            }
        </div>
    </div>
</section>
