---
import { Phone, Menu, X } from "lucide-react";

const links = [
    { href: "/diensten/", label: "Diensten" },
    { href: "/projecten/", label: "Projecten" },
    { href: "/over-ons/", label: "Over Ons" },
    { href: "/contact/", label: "Contact" },
];
---

<header
    class="sticky top-0 z-50 bg-white transition-shadow duration-300"
    id="navbar"
>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16 md:h-20">
            {/* Logo */}
            <a href="/" class="flex items-center">
                <span class="text-primary font-bold text-xl">Groenrijk</span>
                <span class="text-dark font-normal text-xl">&nbsp;Hoveniers</span>
            </a>

            {/* Desktop Navigation */}
            <nav class="hidden md:flex items-center gap-8">
                {
                    links.map((link) => (
                        <a
                            href={link.href}
                            class="text-sm font-medium text-gray-600 hover:text-dark transition-colors duration-200"
                        >
                            {link.label}
                        </a>
                    ))
                }
            </nav>

            {/* Phone Button (Desktop) */}
            <a
                href="tel:0612345678"
                class="hidden md:flex items-center bg-primary text-white rounded-full px-5 py-2.5 text-sm font-medium hover:bg-primary-light transition-colors duration-200"
            >
                <Phone className="w-4 h-4 lg:mr-2" />
                <span class="hidden lg:inline">06-1234 5678</span>
            </a>

            {/* Mobile Actions */}
            <div class="md:hidden flex items-center gap-3">
                <a
                    href="tel:0612345678"
                    class="flex items-center justify-center rounded-full bg-primary text-white w-10 h-10"
                    aria-label="Bel ons"
                >
                    <Phone className="w-4 h-4" />
                </a>
                <button
                    id="mobile-menu-btn"
                    class="p-2 text-dark"
                    aria-label="Menu openen"
                >
                    <Menu className="w-6 h-6" aria-hidden="true" />
                </button>
            </div>
        </div>
    </div>
</header>

{/* Mobile Menu Overlay */}
<div
    id="mobile-menu"
    class="fixed inset-0 z-50 bg-white transform translate-x-full transition-transform duration-300 md:hidden flex flex-col"
>
    {/* Mobile Menu Header */}
    <div class="flex justify-between items-center h-16 px-4 sm:px-6">
        <a href="/" class="flex items-center">
            <span class="text-primary font-bold text-xl">Groenrijk</span>
            <span class="text-dark font-normal text-xl">&nbsp;Hoveniers</span>
        </a>
        <button
            id="close-menu-btn"
            class="p-2 text-dark"
            aria-label="Menu sluiten"
        >
            <X className="w-6 h-6" aria-hidden="true" />
        </button>
    </div>

    {/* Mobile Nav Links */}
    <nav class="flex flex-col gap-4 px-8 pt-8">
        {
            links.map((link) => (
                <a
                    href={link.href}
                    class="text-2xl font-semibold text-dark hover:text-primary transition-colors duration-200"
                >
                    {link.label}
                </a>
            ))
        }
    </nav>

    {/* Mobile Bottom Section */}
    <div class="mt-auto px-8 pb-12 pt-8 flex flex-col gap-5">
        <a
            href="tel:0612345678"
            class="flex items-center text-lg text-dark"
        >
            <Phone className="w-5 h-5 mr-3" />
            06-1234 5678
        </a>
        <a
            href="/contact/"
            class="bg-primary text-white text-center py-4 rounded-full font-medium text-sm hover:bg-primary-light transition-colors duration-200"
        >
            Offerte Aanvragen
        </a>
    </div>
</div>

<script>
    const mobileMenuBtn = document.getElementById("mobile-menu-btn");
    const closeMenuBtn = document.getElementById("close-menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");
    const navbar = document.getElementById("navbar");

    function toggleMenu() {
        mobileMenu?.classList.toggle("translate-x-full");
        document.body.classList.toggle("overflow-hidden");
    }

    mobileMenuBtn?.addEventListener("click", toggleMenu);
    closeMenuBtn?.addEventListener("click", toggleMenu);

    function updateShadow() {
        if (!navbar) return;
        if (window.scrollY > 10) {
            navbar.classList.add("shadow-sm");
        } else {
            navbar.classList.remove("shadow-sm");
        }
    }

    window.addEventListener("scroll", updateShadow, { passive: true });
    updateShadow();
</script>
