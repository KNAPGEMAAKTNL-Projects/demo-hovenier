---
import FadeIn from "./ui/FadeIn";

const reviews = [
    {
        stars: 5,
        time: "2 maanden geleden",
        quote: "Heel blij met onze nieuwe tuin! Het team van Groenrijk heeft precies begrepen wat we wilden. Vakkundig en netjes gewerkt.",
        name: "Jan de V. · Culemborg",
    },
    {
        stars: 5,
        time: "3 maanden geleden",
        quote: "Van ontwerp tot aanleg alles perfect geregeld. De tuin ziet er prachtig uit, zelfs mooier dan we hadden verwacht.",
        name: "Marieke S. · Tiel",
    },
    {
        stars: 5,
        time: "1 maand geleden",
        quote: "Al jaren ons tuinonderhoud bij Groenrijk. Altijd betrouwbaar, flexibel en de tuin ziet er het hele jaar goed uit.",
        name: "Peter K. · Geldermalsen",
    },
];
---

<section class="bg-white py-20 md:py-28">
    <FadeIn client:visible delay={0.1}>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <!-- Header -->
            <div class="text-center">
                <span class="text-primary text-sm font-medium tracking-wide uppercase">Wat onze klanten zeggen</span>
                <h2 class="text-3xl md:text-4xl font-bold text-dark mt-3">Beoordeeld met een 4.8 uit 47 reviews</h2>
                <div class="mt-4 flex items-center justify-center gap-3">
                    <div class="flex items-center gap-0.5">
                        {Array.from({ length: 5 }).map(() => (
                            <svg class="w-5 h-5 text-gold fill-current" viewBox="0 0 20 20">
                                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                            </svg>
                        ))}
                    </div>
                    <span class="text-gray-500 text-sm font-medium">Google Reviews</span>
                </div>
            </div>

            <!-- Review Cards -->
            <div class="mt-12 flex md:grid md:grid-cols-3 gap-6 overflow-x-auto snap-x snap-mandatory md:overflow-visible pb-4 md:pb-0 -mx-4 px-4 md:mx-0 md:px-0">
                {reviews.map((review) => (
                    <div class="snap-center min-w-[85%] sm:min-w-[70%] md:min-w-0 flex-shrink-0 md:flex-shrink bg-gray rounded-2xl p-6">
                        <div class="flex items-center gap-1">
                            {Array.from({ length: review.stars }).map(() => (
                                <svg class="w-4 h-4 text-gold fill-current" viewBox="0 0 20 20">
                                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                </svg>
                            ))}
                            <span class="text-gray-400 text-xs ml-auto">{review.time}</span>
                        </div>
                        <p class="mt-4 text-dark text-sm leading-relaxed">{review.quote}</p>
                        <p class="mt-4 text-gray-500 text-sm font-medium">{review.name}</p>
                    </div>
                ))}
            </div>

            <!-- Link -->
            <div class="mt-8 text-center">
                <a href="#" class="text-primary font-medium text-sm hover:underline inline-flex items-center gap-2">
                    Bekijk alle reviews op Google →
                </a>
            </div>
        </div>
    </FadeIn>
</section>
