---
import { Image } from "astro:assets";
import heroImage from "../assets/images/hero-garden.webp";
import FadeIn from "./ui/FadeIn.tsx";
---

<section class="bg-white py-16 md:py-20 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
            {/* Left column — content */}
            <FadeIn client:visible delay={0.1} direction="up">
                <span class="inline-block bg-primary/10 text-primary rounded-full px-4 py-1.5 text-sm font-medium mb-6">
                    Hovenier in de Betuwe
                </span>

                <h1 class="text-4xl md:text-5xl lg:text-[3.5rem] font-bold text-dark leading-tight">
                    Een mooie tuin begint bij een goede hovenier
                </h1>

                <p class="text-lg text-gray-600 mt-6 leading-relaxed">
                    Van tuinontwerp tot onderhoud. Wij maken van uw tuin een plek om van te genieten.
                </p>

                <div class="mt-8 flex flex-col sm:flex-row gap-4">
                    <a
                        href="/contact/"
                        class="bg-primary hover:bg-primary-light text-white rounded-lg px-6 py-3.5 font-medium transition-colors duration-200 text-center"
                    >
                        Gratis Offerte Aanvragen
                    </a>
                    <a
                        href="/projecten/"
                        class="border border-dark text-dark hover:bg-dark hover:text-white rounded-lg px-6 py-3.5 font-medium transition-colors duration-200 text-center"
                    >
                        Bekijk Onze Projecten
                    </a>
                </div>

                <div class="mt-8 flex flex-wrap items-center gap-6 text-sm text-gray-600">
                    {/* Google stars */}
                    <div class="flex items-center gap-2">
                        <div class="flex gap-0.5">
                            {Array.from({ length: 5 }).map(() => (
                                <svg class="w-4 h-4" viewBox="0 0 20 20" fill="#F59E0B" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                </svg>
                            ))}
                        </div>
                        <span>4.8 — 47 reviews</span>
                    </div>

                    <div class="hidden sm:block w-px h-5 bg-gray-300"></div>

                    <span>15+ jaar ervaring</span>

                    <div class="hidden sm:block w-px h-5 bg-gray-300"></div>

                    <span>VHG Gecertificeerd</span>
                </div>
            </FadeIn>

            {/* Right column — image */}
            <FadeIn client:visible delay={0.3} direction="right">
                <Image
                    src={heroImage}
                    alt="Zonnige moderne tuin met weelderige beplanting in de Betuwe"
                    class="rounded-2xl object-cover w-full h-full max-h-[500px] lg:max-h-none"
                    widths={[480, 768, 1024]}
                    sizes="(max-width: 1024px) 100vw, 50vw"
                    loading="eager"
                    fetchpriority="high"
                />
            </FadeIn>
        </div>
    </div>
</section>
