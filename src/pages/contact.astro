---
import Layout from "../layouts/Layout.astro";
import { Phone, Mail, MessageCircle, CheckCircle } from "lucide-react";
---

<Layout title="Contact | Groenrijk Hoveniers">
    <main>
        {/* Page header */}
        <section class="bg-white py-16 md:py-20 pt-28 md:pt-36">
            <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
                <span class="inline-block text-sm font-medium text-primary bg-primary/10 px-4 py-1.5 rounded-full mb-4">Neem contact op</span>
                <h1 class="text-4xl md:text-5xl font-bold text-dark">Contact</h1>
                <p class="text-gray-600 mt-4 text-lg max-w-xl mx-auto">
                    Bent u benieuwd naar de mogelijkheden voor uw tuin? Wij komen graag vrijblijvend langs voor een kennismaking.
                </p>
            </div>
        </section>

        {/* Contact method cards */}
        <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
                <a href="tel:0612345678" class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 text-center hover:shadow-md transition-shadow">
                    <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mx-auto">
                        <Phone className="w-6 h-6 text-primary" />
                    </div>
                    <h3 class="font-bold text-dark mt-4">Bel ons</h3>
                    <span class="text-gray-600 text-sm mt-1 block">06-1234 5678</span>
                </a>
                <a href="mailto:info@groenrijkhoveniers.nl" class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 text-center hover:shadow-md transition-shadow">
                    <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mx-auto">
                        <Mail className="w-6 h-6 text-primary" />
                    </div>
                    <h3 class="font-bold text-dark mt-4">E-mail</h3>
                    <span class="text-gray-600 text-sm mt-1 block">info@groenrijkhoveniers.nl</span>
                </a>
                <a href="https://wa.me/31612345678" target="_blank" class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 text-center hover:shadow-md transition-shadow">
                    <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mx-auto">
                        <MessageCircle className="w-6 h-6 text-primary" />
                    </div>
                    <h3 class="font-bold text-dark mt-4">WhatsApp</h3>
                    <span class="text-gray-600 text-sm mt-1 block">Stuur een bericht</span>
                </a>
            </div>
        </section>

        {/* Main content: sidebar + form */}
        <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-16 pb-20">
            <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
                {/* Left column */}
                <div class="lg:col-span-2">
                    <h2 class="text-xl font-bold text-dark">Werkgebied</h2>
                    <p class="text-gray-600 mt-3">
                        Wij zijn actief in Culemborg en omstreken, waaronder de Betuwe en het Rivierenland.
                    </p>
                    <p class="text-gray-600 mt-2">
                        Culemborg, Tiel, Geldermalsen, Buren, Beusichem, Leerdam
                    </p>

                    <h2 class="text-xl font-bold text-dark mt-8">Wat kunt u verwachten?</h2>
                    <ul class="mt-3 space-y-2">
                        <li class="flex items-center gap-2 text-gray-600">
                            <CheckCircle className="w-5 h-5 text-primary flex-shrink-0" />
                            <span>Reactie binnen 24 uur</span>
                        </li>
                        <li class="flex items-center gap-2 text-gray-600">
                            <CheckCircle className="w-5 h-5 text-primary flex-shrink-0" />
                            <span>Gratis en vrijblijvend adviesgesprek</span>
                        </li>
                        <li class="flex items-center gap-2 text-gray-600">
                            <CheckCircle className="w-5 h-5 text-primary flex-shrink-0" />
                            <span>Transparante offerte op maat</span>
                        </li>
                        <li class="flex items-center gap-2 text-gray-600">
                            <CheckCircle className="w-5 h-5 text-primary flex-shrink-0" />
                            <span>Persoonlijke aanpak</span>
                        </li>
                    </ul>
                </div>

                {/* Right column */}
                <div class="lg:col-span-3">
                    <div id="form-card" class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
                        <h2 class="text-2xl font-bold text-dark mb-6">Stuur ons een bericht</h2>

                        <form id="contact-form" action="/api/send-email/" method="POST" class="space-y-5">
                            <div>
                                <label for="naam" class="text-sm font-medium text-dark mb-1.5 block">Naam</label>
                                <input
                                    type="text"
                                    id="naam"
                                    name="naam"
                                    required
                                    class="w-full border border-gray-200 rounded-lg px-4 py-3 text-dark focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors"
                                />
                            </div>
                            <div>
                                <label for="telefoon" class="text-sm font-medium text-dark mb-1.5 block">Telefoon</label>
                                <input
                                    type="tel"
                                    id="telefoon"
                                    name="telefoon"
                                    class="w-full border border-gray-200 rounded-lg px-4 py-3 text-dark focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors"
                                />
                            </div>
                            <div>
                                <label for="email" class="text-sm font-medium text-dark mb-1.5 block">Email</label>
                                <input
                                    type="email"
                                    id="email"
                                    name="email"
                                    required
                                    class="w-full border border-gray-200 rounded-lg px-4 py-3 text-dark focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors"
                                />
                            </div>
                            <div>
                                <label for="bericht" class="text-sm font-medium text-dark mb-1.5 block">Bericht</label>
                                <textarea
                                    id="bericht"
                                    name="bericht"
                                    rows="5"
                                    required
                                    class="w-full border border-gray-200 rounded-lg px-4 py-3 text-dark focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors resize-none"
                                ></textarea>
                            </div>

                            <button
                                type="submit"
                                class="w-full bg-primary hover:bg-primary-light text-white rounded-lg py-3.5 font-medium transition-colors duration-200 mt-6"
                            >
                                Verstuur Bericht
                            </button>
                        </form>
                    </div>

                    {/* Success message */}
                    <div id="success-message" class="hidden bg-primary/10 rounded-2xl p-8 text-center">
                        <div class="w-16 h-16 mx-auto mb-4 flex items-center justify-center">
                            <CheckCircle className="w-12 h-12 text-primary" />
                        </div>
                        <h3 class="text-2xl font-bold text-dark mb-2">Bedankt voor uw bericht!</h3>
                        <p class="text-gray-600 mb-6">We nemen zo snel mogelijk contact met u op.</p>
                        <a href="/" class="inline-block text-primary font-medium hover:underline">Terug naar home</a>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>

<script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const successMessage = document.getElementById('success-message');
    const formCard = document.getElementById('form-card');

    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
        submitBtn.disabled = true;
        submitBtn.textContent = 'Versturen...';

        try {
            const formData = new FormData(form);
            const data = Object.fromEntries(formData);
            const response = await fetch('/api/send-email/', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data),
            });

            if (response.ok) {
                formCard?.classList.add('hidden');
                successMessage?.classList.remove('hidden');
            } else {
                throw new Error('Submission failed');
            }
        } catch (error) {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Verstuur Bericht';
            alert('Er is iets misgegaan. Probeer het opnieuw of neem telefonisch contact op.');
        }
    });
</script>
