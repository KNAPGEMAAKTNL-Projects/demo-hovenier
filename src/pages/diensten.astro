---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import FadeIn from "../components/ui/FadeIn";
import { Check } from "lucide-react";

import tuinontwerpImage from "../assets/images/tuinontwerp-en-advies.webp";
import tuinaanlegImage from "../assets/images/tuinaanleg.webp";
import tuinonderhoudImage from "../assets/images/tuinonderhoud.webp";

const services = [
    {
        id: "ontwerp",
        title: "Tuinontwerp & Advies",
        alt: "Professioneel tuinontwerp met beplantingsplan op tafel in Culemborg",
        description:
            "Een goed ontwerp is de basis van elke mooie tuin. Wij luisteren naar uw wensen, bekijken de mogelijkheden en vertalen dat naar een ontwerp dat past bij uw woning en leefstijl.",
        features: [
            "Persoonlijk intakegesprek",
            "Creatief tuinontwerp op maat",
            "3D visualisatie",
            "Beplantingsplan",
            "Verlichtingsadvies",
        ],
        image: tuinontwerpImage,
    },
    {
        id: "aanleg",
        title: "Tuinaanleg",
        alt: "Vakkundige tuinaanleg met sierbestrating en groene borders",
        description:
            "Van de eerste schop in de grond tot het laatste plantje — wij realiseren uw droomtuin met vakmanschap en oog voor detail.",
        features: [
            "Bestrating en terrassen",
            "Houtwerk en overkappingen",
            "Waterpartijen",
            "Gazon en grondwerk",
            "Beplanting",
        ],
        image: tuinaanlegImage,
    },
    {
        id: "onderhoud",
        title: "Tuinonderhoud",
        alt: "Seizoensgebonden tuinonderhoud met snoeiwerk en beplanting",
        description:
            "Een mooie tuin verdient goed onderhoud. Met een onderhoudsabonnement zorgen wij ervoor dat uw tuin er het hele jaar prachtig uitziet.",
        features: [
            "Snoeiwerk",
            "Onkruidbestrijding",
            "Gazon- en borderonderhoud",
            "Boomverzorging",
            "Vakantieservice",
        ],
        image: tuinonderhoudImage,
    },
];
---

<Layout title="Diensten | Groenrijk Hoveniers">
    <main>
        {/* Page Header */}
        <section class="bg-primary py-20 md:py-28 pt-28 md:pt-36">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <FadeIn client:visible>
                    <span class="text-white/80 text-sm tracking-wide uppercase font-medium">Expertise</span>
                    <h1 class="text-white text-4xl md:text-5xl font-bold mt-3">
                        Onze Diensten
                    </h1>
                    <p class="text-white/80 mt-4 max-w-2xl">
                        Van eerste ontwerp tot jarenlang onderhoud — wij zijn uw partner in groen.
                    </p>
                </FadeIn>
            </div>
        </section>

        {/* Service Sections */}
        {
            services.map((service, index) => (
                <section
                    id={service.id}
                    class={`py-20 md:py-28 ${index % 2 === 1 ? "bg-[#F5F5F5]" : "bg-white"}`}
                >
                    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
                            {/* Image */}
                            <FadeIn client:visible delay={0.1}>
                                <div class={index % 2 === 1 ? "lg:order-2" : ""}>
                                    <Image
                                        src={service.image}
                                        alt={service.alt}
                                        class="rounded-2xl w-full object-cover"
                                        widths={[480, 768, 1024]}
                                        sizes="(max-width: 1024px) 100vw, 50vw"
                                        loading="lazy"
                                        decoding="async"
                                    />
                                </div>
                            </FadeIn>

                            {/* Content */}
                            <FadeIn client:visible delay={0.2}>
                                <div class={index % 2 === 1 ? "lg:order-1" : ""}>
                                    <h2 class="text-3xl md:text-4xl font-bold text-[#1A1A1A]">
                                        {service.title}
                                    </h2>
                                    <p class="text-gray-600 mt-4 leading-relaxed">
                                        {service.description}
                                    </p>
                                    <ul class="space-y-3 mt-6">
                                        {service.features.map((feature) => (
                                            <li class="flex items-start gap-3">
                                                <Check className="w-5 h-5 text-primary flex-shrink-0 mt-0.5" />
                                                <span class="text-gray-600">{feature}</span>
                                            </li>
                                        ))}
                                    </ul>
                                </div>
                            </FadeIn>
                        </div>
                    </div>
                </section>
            ))
        }

        {/* CTA Band */}
        <section class="py-20 md:py-28">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="bg-primary rounded-2xl py-16 px-8 text-center">
                    <FadeIn client:visible>
                        <h2 class="text-white text-3xl md:text-4xl font-bold">
                            Klaar om uw tuin aan te pakken?
                        </h2>
                        <p class="text-white/80 mt-4">
                            Neem contact op voor een vrijblijvend adviesgesprek.
                        </p>
                        <a
                            href="/contact/"
                            class="inline-block bg-white text-primary px-8 py-3 rounded-lg font-medium mt-8 hover:bg-white/90 transition-colors"
                        >
                            Contact Opnemen
                        </a>
                    </FadeIn>
                </div>
            </div>
        </section>
    </main>
</Layout>
