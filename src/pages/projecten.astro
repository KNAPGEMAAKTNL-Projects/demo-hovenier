---
import Layout from "../layouts/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import FadeIn from "../components/ui/FadeIn";

import gerealiseerdeImage from "../assets/images/gerealiseerde-tuin.webp";
import tuinonderhoudImage from "../assets/images/tuinonderhoud.webp";
import tuinaanlegImage from "../assets/images/tuinaanleg.webp";
import tuinontwerpImage from "../assets/images/tuinontwerp-en-advies.webp";

const projects = [
    {
        title: "Stadstuin aan de Lek",
        slug: "stadstuin-aan-de-lek",
        category: "Tuinaanleg & Ontwerp",
        image: gerealiseerdeImage,
        link: "/projecten/stadstuin-aan-de-lek/",
        tags: ["Bestrating", "Verlichting", "Beplanting"],
        description: "Moderne stadstuin met strakke lijnen en weelderig groen, gerealiseerd door Groenrijk Hoveniers.",
    },
    {
        title: "Landelijke Villa Beusichem",
        slug: "landelijke-villa-beusichem",
        category: "Renovatie",
        image: tuinonderhoudImage,
        link: "/projecten/landelijke-villa-beusichem/",
        tags: ["Zwemvijver", "Oud Hollands", "Gazon"],
        description: "Klassieke villatuin gerenoveerd met nieuwe zichtlijnen en een natuurlijke zwemvijver.",
    },
    {
        title: "Moderne Patiotuin",
        slug: "moderne-patiotuin",
        category: "Tuinaanleg",
        image: tuinaanlegImage,
        link: "/projecten/moderne-patiotuin/",
        tags: ["Keramiek", "Overkapping", "Privacy"],
        description: "Compacte patiotuin als verlengstuk van de woonkamer, ontworpen door Groenrijk.",
    },
    {
        title: "Bedrijfstuin Culemborg",
        slug: "bedrijfstuin-culemborg",
        category: "Onderhoud & Aanleg",
        image: tuinontwerpImage,
        link: "/projecten/bedrijfstuin-culemborg/",
        tags: ["Representatief", "Onderhoudsarm", "Entree"],
        description: "Representatieve bedrijfsentree met duurzame groene uitstraling door Groenrijk Hoveniers.",
    },
];
---

<Layout title="Projecten | Groenrijk Hoveniers">
    <main>
        {/* Page Header */}
        <section class="bg-white py-20 md:py-28 pt-28 md:pt-36">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <FadeIn client:visible delay={0.1}>
                    <div class="max-w-2xl">
                        <span class="text-primary text-sm font-medium tracking-wide uppercase">Ons werk</span>
                        <h1 class="text-4xl md:text-5xl font-bold text-dark mt-3">
                            Onze Projecten
                        </h1>
                        <p class="text-gray-600 mt-4 max-w-2xl">
                            Van stadstuin tot landelijke tuin — bekijk een selectie van onze gerealiseerde projecten.
                        </p>
                    </div>
                </FadeIn>
            </div>
        </section>

        {/* Project Grid */}
        <section class="pb-20 md:pb-28 bg-white">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-12">
                    {
                        projects.map((project, index) => (
                            <FadeIn
                                client:visible
                                delay={index * 0.1}
                                fullWidth
                            >
                                <ProjectCard {...project} />
                            </FadeIn>
                        ))
                    }
                </div>
            </div>
        </section>

        {/* CTA Band */}
        <section class="py-12 md:py-16">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="bg-primary rounded-2xl py-16 px-8 text-center">
                    <FadeIn client:visible direction="up">
                        <h2 class="text-3xl md:text-4xl font-bold text-white">
                            Geïnspireerd geraakt?
                        </h2>
                        <p class="text-white/80 text-lg mt-4">
                            Neem contact op en vertel ons over uw droomtuin.
                        </p>
                        <a
                            href="/contact/"
                            class="inline-block bg-white text-primary px-8 py-3.5 rounded-lg font-medium mt-8 hover:bg-gray-50 transition-colors"
                        >
                            Plan een Kennismaking
                        </a>
                    </FadeIn>
                </div>
            </div>
        </section>
    </main>
</Layout>
