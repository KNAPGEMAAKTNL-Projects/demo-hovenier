---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import FadeIn from "../components/ui/FadeIn";
import overOnsImage from "../assets/images/veluwe.webp";
import { Award, Users, Leaf } from "lucide-react";

const values = [
    {
        icon: Award,
        title: "Vakmanschap",
        desc: "Gecertificeerde hoveniers die werken met de beste materialen en technieken. Kwaliteit die u ziet en voelt.",
    },
    {
        icon: Users,
        title: "Persoonlijk",
        desc: "Eén vast aanspreekpunt, heldere communicatie en een plan dat past bij uw wensen en budget.",
    },
    {
        icon: Leaf,
        title: "Duurzaam",
        desc: "Toekomstgericht tuinieren met aandacht voor biodiversiteit, waterbeheer en onderhoudsgemak.",
    },
];
---

<Layout title="Over Ons | Groenrijk Hoveniers">
    <main>
        {/* Page Header */}
        <section class="bg-white py-20 md:py-28 pt-28 md:pt-36">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <FadeIn client:visible>
                    <span class="text-primary text-sm font-medium tracking-wide uppercase">Wie wij zijn</span>
                    <h1 class="text-4xl md:text-5xl font-bold text-dark mt-3">
                        Over Groenrijk Hoveniers
                    </h1>
                    <p class="text-gray-600 mt-4 max-w-2xl">
                        Uw hovenier in de Betuwe. Met passie voor groen en oog voor kwaliteit.
                    </p>
                </FadeIn>
            </div>
        </section>

        {/* Full-width image band */}
        <section class="px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
            <FadeIn client:visible delay={0.1}>
                <Image
                    src={overOnsImage}
                    alt="Landschap in de Betuwe — het werkgebied van Groenrijk Hoveniers"
                    class="w-full rounded-2xl object-cover aspect-[21/9]"
                    widths={[640, 960, 1280, 1920]}
                    sizes="(max-width: 1280px) 100vw, 1280px"
                    loading="lazy"
                    decoding="async"
                />
            </FadeIn>
        </section>

        {/* Story Section */}
        <section class="bg-white py-20 md:py-28">
            <div class="max-w-3xl mx-auto px-4">
                <FadeIn client:visible delay={0.2}>
                    <h2 class="text-3xl font-bold text-dark">
                        Van Passie naar Professie
                    </h2>
                    <div class="mt-6 text-gray-600 leading-relaxed space-y-4">
                        <p>
                            Bij Groenrijk Hoveniers geloven we dat een tuin meer is dan een stuk groen. Het is een verlengstuk van uw woning, een plek waar herinneringen worden gemaakt. Daarom benaderen wij elk project met dezelfde toewijding en vakmanschap.
                        </p>
                        <p>
                            Opgericht in de Betuwe, kennen wij het landschap en de grond als geen ander. Of het nu gaat om een compact stadsterras of een uitgestrekte landelijke tuin — wij weten wat werkt en wat groeit.
                        </p>
                        <p>
                            Ons team bestaat uit gedreven hoveniers die hun vak verstaan. We werken met eerlijke materialen, heldere communicatie en een persoonlijke aanpak. Want een mooie tuin maak je samen.
                        </p>
                    </div>
                </FadeIn>
            </div>
        </section>

        {/* Values Section */}
        <section class="bg-gray py-20 md:py-28">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <FadeIn client:visible delay={0.2}>
                    <div class="text-center">
                        <h2 class="text-3xl font-bold text-dark">
                            Waar wij voor staan
                        </h2>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12">
                        {
                            values.map((value) => (
                                <div class="bg-white rounded-2xl p-8 shadow-sm">
                                    <div class="w-14 h-14 bg-primary/10 rounded-xl flex items-center justify-center mb-6">
                                        <value.icon className="text-primary w-7 h-7" />
                                    </div>
                                    <h3 class="text-xl font-bold text-dark mb-3">
                                        {value.title}
                                    </h3>
                                    <p class="text-gray-600 leading-relaxed">
                                        {value.desc}
                                    </p>
                                </div>
                            ))
                        }
                    </div>
                </FadeIn>
            </div>
        </section>

        {/* CTA Band */}
        <section class="py-12 md:py-16">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <FadeIn client:visible>
                    <div class="bg-primary rounded-2xl py-16 px-8 text-center">
                        <h2 class="text-3xl md:text-4xl font-bold text-white">
                            Benieuwd wat wij voor u kunnen betekenen?
                        </h2>
                        <a
                            href="/contact/"
                            class="inline-block mt-8 bg-white text-primary px-8 py-3 rounded-lg font-medium hover:bg-gray-100 transition-colors"
                        >
                            Neem Contact Op
                        </a>
                    </div>
                </FadeIn>
            </div>
        </section>
    </main>
</Layout>
