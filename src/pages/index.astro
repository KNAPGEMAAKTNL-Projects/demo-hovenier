---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import ServicesGrid from "../components/ServicesGrid.astro";
import ReviewsSection from "../components/ReviewsSection.astro";
import FadeIn from "../components/ui/FadeIn";
import { Image } from "astro:assets";
import { Phone, ArrowRight } from "lucide-react";
import gerealiseerdeImage from "../assets/images/gerealiseerde-tuin.webp";
---

<Layout title="Groenrijk Hoveniers | Uw Hovenier in de Betuwe">
	<main>
		<Hero />
		<ServicesGrid />
		<ReviewsSection />

		{/* Featured Project */}
		<section class="py-20 md:py-28">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<FadeIn client:visible delay={0.1}>
					<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
						<div class="rounded-2xl overflow-hidden">
							<Image
								src={gerealiseerdeImage}
								alt="Stadstuin in Culemborg met terras, beplanting en verlichting"
								class="w-full aspect-[4/3] object-cover"
								widths={[480, 768, 1024]}
								sizes="(max-width: 1024px) 100vw, 50vw"
								loading="lazy"
								decoding="async"
							/>
						</div>
						<div>
							<span class="text-primary text-sm font-medium tracking-wide uppercase">Uitgelicht Project</span>
							<h2 class="text-3xl md:text-4xl font-bold text-dark mt-3">Stadstuin in Culemborg</h2>
							<p class="text-gray-600 mt-4 leading-relaxed">Complete tuinrenovatie met terras, beplanting en verlichting. Een compacte stadstuin omgetoverd tot een groene oase.</p>
							<a
								href="/projecten/stadstuin-aan-de-lek/"
								class="mt-6 inline-flex items-center gap-2 bg-primary hover:bg-primary-light text-white rounded-lg px-6 py-3 font-medium transition-colors duration-200"
							>
								Bekijk dit project <ArrowRight className="w-4 h-4" />
							</a>
						</div>
					</div>
				</FadeIn>
			</div>
		</section>

		{/* CTA Band */}
		<section class="py-12 md:py-16">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="bg-primary rounded-2xl py-16 px-8 text-center">
					<h2 class="text-white text-3xl md:text-4xl font-bold">Klaar voor een nieuwe tuin?</h2>
					<p class="text-white/80 mt-4 max-w-xl mx-auto">Vraag vrijblijvend een offerte aan of bel ons direct.</p>
					<div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
						<a
							href="/contact/"
							class="bg-white text-primary rounded-lg px-6 py-3.5 font-medium hover:bg-gray-100 transition-colors duration-200"
						>
							Offerte Aanvragen
						</a>
						<a
							href="tel:0623571852"
							class="border border-white/30 hover:bg-white/10 text-white rounded-lg px-6 py-3.5 font-medium transition-all duration-200 inline-flex items-center gap-2 justify-center"
						>
							<Phone className="w-4 h-4" />
							Bel Direct
						</a>
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>
