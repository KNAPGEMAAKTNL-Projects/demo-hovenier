---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import ServicesGrid from "../components/ServicesGrid.astro";
import ReviewsSection from "../components/ReviewsSection.astro";
import FadeIn from "../components/ui/FadeIn";
import { Image } from "astro:assets";
import { Phone } from "lucide-react";
import gerealiseerdeImage from "../assets/images/gerealiseerde-tuin.webp";
---

<Layout title="Groenrijk Hoveniers | Uw Hovenier in de Betuwe">
	<main>
		<Hero />
		<ServicesGrid />
		<ReviewsSection />

		{/* Featured Project */}
		<section class="py-20 md:py-28">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<FadeIn client:visible delay={0.1}>
					<div class="relative rounded-2xl overflow-hidden">
						<Image
							src={gerealiseerdeImage}
							alt="Stadstuin in Culemborg met terras, beplanting en verlichting"
							class="w-full aspect-[16/7] object-cover"
							widths={[640, 960, 1280, 1920]}
							sizes="(max-width: 1280px) 100vw, 1280px"
							loading="lazy"
							decoding="async"
						/>
						<div class="absolute inset-0 bg-gradient-to-t from-dark/70 via-dark/30 to-transparent"></div>
						<div class="absolute inset-0 flex flex-col items-center justify-end pb-12 md:pb-16 px-6 text-center">
							<span class="text-white/80 text-sm tracking-wide uppercase font-medium">Uitgelicht Project</span>
							<h2 class="text-white text-3xl md:text-4xl font-bold mt-2">Stadstuin in Culemborg</h2>
							<p class="text-white/80 mt-3 max-w-lg">Complete tuinrenovatie met terras, beplanting en verlichting.</p>
							<a
								href="/projecten/"
								class="mt-6 border border-white/50 hover:border-white hover:bg-white/10 text-white rounded-lg px-6 py-3 font-medium transition-all duration-200"
							>
								Bekijk dit project &rarr;
							</a>
						</div>
					</div>
				</FadeIn>
			</div>
		</section>

		{/* CTA Band */}
		<section class="py-12 md:py-16">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="bg-primary rounded-2xl py-16 px-8 text-center">
					<h2 class="text-white text-3xl md:text-4xl font-bold">Klaar voor een nieuwe tuin?</h2>
					<p class="text-white/80 mt-4 max-w-xl mx-auto">Vraag vrijblijvend een offerte aan of bel ons direct.</p>
					<div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
						<a
							href="/contact/"
							class="bg-white text-primary hover:bg-gray-100 rounded-lg px-6 py-3.5 font-medium transition-colors duration-200"
						>
							Offerte Aanvragen
						</a>
						<a
							href="tel:0612345678"
							class="border border-white/50 hover:border-white hover:bg-white/10 text-white rounded-lg px-6 py-3.5 font-medium transition-all duration-200 inline-flex items-center gap-2 justify-center"
						>
							<Phone className="w-4 h-4" />
							Bel Direct
						</a>
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>
